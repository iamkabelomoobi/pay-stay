{
  "name": "@kasistay/server",
  "version": "1.0.0",
  "description": "",
  "main": "src/index.ts",
  "scripts": {
    "dev": "nodemon",
    "start": "node --experimental-specifier-resolution=node dist/index.js",
    "build": "tsc && node ../../scripts/fix-esm-specifiers.mjs dist",
    "start:build": "npm run build --workspace @kasistay/db && npm run build --workspace @kasistay/logger && npm run build --workspace @kasistay/email && npm run build --workspace @kasistay/auth && npm run build && node --experimental-specifier-resolution=node dist/index.js",
    "start:pm2": "npm run build && pm2 start ecosystem.config.cjs",
    "restart:pm2": "pm2 restart ecosystem.config.cjs",
    "stop:pm2": "pm2 delete ecosystem.config.cjs",
    "check-types": "tsc --noEmit",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "test:integration": "RUN_SERVER_INTEGRATION_TESTS=1 node --import tsx --test tests/**/*.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/ip": "^1.1.3",
    "@types/mailgen": "^2.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.15",
    "@types/nodemailer": "^7.0.11",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "@as-integrations/express4": "^1.1.2",
    "@kasistay/logger": "^1.0.0",
    "@faker-js/faker": "^10.3.0",
    "@logtail/node": "^0.5.8",
    "@logtail/winston": "^0.5.8",
    "@pothos/core": "^4.12.0",
    "@pothos/plugin-errors": "^4.9.0",
    "@pothos/plugin-prisma": "^4.14.2",
    "@pothos/plugin-scope-auth": "^4.1.6",
    "@pothos/plugin-simple-objects": "^4.1.3",
    "@pothos/plugin-validation": "^4.2.0",
    "@types/cors": "^2.8.19",
    "better-auth": "^1.5.5",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.6",
    "dotenv": "^16.0.3",
    "graphql": "^16.13.1",
    "graphql-tag": "^2.12.6",
    "ip": "^2.0.1",
    "mailgen": "^2.0.32",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "resend": "^6.9.4",
    "winston": "^3.19.0"
  }
